{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "server.ts",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/server.ts"
    },
    {
      "source": "/((?!api|assets|sw.js|manifest.webmanifest|icon.svg|favicon.ico|apple-touch-icon.png|mask-icon.svg).*)",
      "destination": "/index.html"
    }
  ]
}
