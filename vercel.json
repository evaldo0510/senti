{
  "version": 2,
  "framework": "vite",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/((?!assets/|favicon.ico|icon.svg|manifest.json|sw.js|manifest.webmanifest).*)",
      "destination": "/index.html"
    }
  ]
}
