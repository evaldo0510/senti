rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Reusable, hardened global helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }

    function getUserTenantId() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) ? 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('tenantId', null) : 
        null;
    }

    function getUserType() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) ? 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('tipo', null) : 
        null;
    }

    function isSystemAdmin() {
      return isSignedIn() && (getUserType() == 'admin' || getUserType() == 'super_admin');
    }

    function isSameTenant(data) {
      return !exists(/databases/$(database)/documents/users/$(request.auth.uid)) || 
             (data != null && data.get('tenantId', null) == getUserTenantId());
    }

    // --- Users Collection Rules ---
    match /users/{userId} {
      // If the logged-in user is the owner, allow get/create/update immediately.
      // This breaks any circular helper function dependency for standard self-access.
      allow get, create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && request.auth.uid == userId && (
        !incoming().keys().hasAny(['tipo']) || 
        incoming().get('tipo', null) == existing().get('tipo', null)
      );

      // If the logged-in user is NOT the owner, evaluate admin and relationship-based access.
      allow get: if isSignedIn() && request.auth.uid != userId && (
        isSystemAdmin() || (
          resource != null && (
            resource.data.get('tipo', null) == 'terapeuta' || (
              exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
              getUserTenantId() == resource.data.get('tenantId', null)
            )
          )
        )
      );

      allow list: if isSignedIn() && (
        isSystemAdmin() || (
          resource != null && (
            resource.data.get('tipo', null) == 'terapeuta' || (
              exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
              getUserTenantId() == resource.data.get('tenantId', null) && 
              (getUserType() == 'admin' || 
               getUserType() == 'super_admin' || 
               getUserType() == 'admin_institucional' || 
               getUserType() == 'prefeitura' || 
               getUserType() == 'empresa' || 
               getUserType() == 'clinica' || 
               getUserType() == 'hospital')
            )
          )
        )
      );

      allow create: if isSignedIn() && request.auth.uid != userId && isSystemAdmin();

      allow update: if isSignedIn() && request.auth.uid != userId && (
        isSystemAdmin() || (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          (getUserType() == 'admin' || 
               getUserType() == 'super_admin' || 
               getUserType() == 'admin_institucional' || 
               getUserType() == 'prefeitura' || 
               getUserType() == 'empresa' || 
               getUserType() == 'clinica' || 
               getUserType() == 'hospital') &&
          (resource != null && isSameTenant(resource.data)) && 
          isSameTenant(incoming())
        )
      );

      allow delete: if isSignedIn() && request.auth.uid != userId && isSystemAdmin();
    }

    // --- Appointments Collection Rules ---
    match /appointments/{appointmentId} {
      allow read, write: if isSystemAdmin();
      allow get, list: if isSignedIn() && resource != null && (
        (resource.data.get('patientId', null) == request.auth.uid ||
         resource.data.get('therapistId', null) == request.auth.uid) &&
        isSameTenant(resource.data)
      );
      allow create: if isSignedIn() && (
        (incoming().get('patientId', null) == request.auth.uid ||
         incoming().get('therapistId', null) == request.auth.uid) &&
        isSameTenant(incoming())
      );
      allow update: if isSignedIn() && resource != null && (
        (resource.data.get('patientId', null) == request.auth.uid ||
         resource.data.get('therapistId', null) == request.auth.uid) &&
        isSameTenant(resource.data) &&
        isSameTenant(incoming())
      );
    }

    // --- Messages Collection Rules ---
    match /messages/{messageId} {
      allow read, write: if isSystemAdmin();
      allow get, list: if isSignedIn() && resource != null && (
        resource.data.get('senderId', null) == request.auth.uid ||
        resource.data.get('receiverId', null) == request.auth.uid
      );
      allow create: if isSignedIn() && (
        incoming().get('senderId', null) == request.auth.uid
      );
    }

    // --- Emotion Logs Collection Rules ---
    match /emotion_logs/{logId} {
      allow read, write: if isSystemAdmin();
      allow get, list: if isSignedIn() && (resource == null || resource.data.get('userId', null) == request.auth.uid);
      allow create: if isSignedIn() && incoming().get('userId', null) == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.get('userId', null) == request.auth.uid;
    }

    // --- Breathing Logs Collection Rules ---
    match /breathing_logs/{logId} {
      allow read, write: if isSystemAdmin();
      allow get, list: if isSignedIn() && (resource == null || resource.data.get('userId', null) == request.auth.uid);
      allow create: if isSignedIn() && incoming().get('userId', null) == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.get('userId', null) == request.auth.uid;
    }

    // --- IARA AI Memory Collection Rules ---
    match /memoria_iara/{userId} {
      allow read, write: if isSystemAdmin();
      allow read, write: if isOwner(userId);
    }

    // --- IARA Conversations Collection Rules ---
    match /iara_conversations/{conversationId} {
      allow read, write: if isSystemAdmin();
      allow get, list: if isSignedIn() && (resource == null || resource.data.get('userId', null) == request.auth.uid);
      allow create: if isSignedIn() && incoming().get('userId', null) == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.get('userId', null) == request.auth.uid;
    }

    // --- Diary Entries Collection Rules ---
    match /diary_entries/{entryId} {
      allow read, write: if isSystemAdmin();
      allow get, list: if isSignedIn() && (resource == null || resource.data.get('userId', null) == request.auth.uid);
      allow create: if isSignedIn() && incoming().get('userId', null) == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.get('userId', null) == request.auth.uid;
    }

    // --- Feedbacks Collection Rules ---
    match /feedbacks/{feedbackId} {
      allow read, write: if isSystemAdmin();
      allow get, list: if isSignedIn() && (resource == null || resource.data.get('userId', null) == request.auth.uid);
      allow create: if isSignedIn() && incoming().get('userId', null) == request.auth.uid;
    }

    // --- Private Clinical Notes Collection Rules ---
    match /private_notes/{noteId} {
      allow read, write: if isSystemAdmin();
      allow get, list: if isSignedIn() && resource != null && (
        (resource.data.get('patientId', null) == request.auth.uid ||
         resource.data.get('therapistId', null) == request.auth.uid) &&
        isSameTenant(resource.data)
      );
      allow create: if isSignedIn() && (
        incoming().get('therapistId', null) == request.auth.uid &&
        isSameTenant(incoming())
      );
      allow update, delete: if isSignedIn() && resource != null && (
        resource.data.get('therapistId', null) == request.auth.uid &&
        isSameTenant(resource.data) &&
        isSameTenant(incoming())
      );
    }

    // --- Security Audit Logs Collection Rules ---
    match /audit_logs/{logId} {
      allow read, write: if isSystemAdmin();
      allow create: if true;
      allow get, list: if isSignedIn() && resource != null && resource.data.get('userId', null) == request.auth.uid;
    }

    // --- Organizations Collection Rules ---
    match /organizations/{orgId} {
      allow read: if isSignedIn() && (
        isSystemAdmin() ||
        !exists(/databases/$(database)/documents/users/$(request.auth.uid)) ||
        getUserTenantId() == orgId
      );
      allow create, delete: if isSystemAdmin();
      allow update: if isSignedIn() && (
        isSystemAdmin() || (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          getUserTenantId() == orgId && 
          (getUserType() == 'admin_institucional' || 
           getUserType() == 'empresa' || 
           getUserType() == 'prefeitura' || 
           getUserType() == 'clinica' || 
           getUserType() == 'hospital')
        )
      );
    }
  }
}
