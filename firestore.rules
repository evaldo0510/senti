rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Reusable, hardened global helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }

    function isSystemAdmin() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('tipo', null) == 'admin' || 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('tipo', null) == 'super_admin');
    }

    function hasUserDoc() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function getTenantId(data) {
      return data != null ? data.get('tenantId', null) : null;
    }

    function isSameTenant(data) {
      return !hasUserDoc() || getTenantId(data) == getTenantId(getUserData());
    }

    // --- Users Collection Rules ---
    match /users/{userId} {
      // 1. Owner profile read/write access is isolated and simple
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && request.auth.uid == userId && (
        !incoming().keys().hasAny(['tipo']) || 
        incoming().get('tipo', null) == existing().get('tipo', null)
      );

      // 2. Non-owner (Administrative / Tenant) access
      allow read: if isSignedIn() && request.auth.uid != userId && (
        isSystemAdmin() ||
        (resource != null && hasUserDoc() && isSameTenant(resource.data))
      );
      
      allow create: if isSignedIn() && request.auth.uid != userId && isSystemAdmin();

      allow update: if isSignedIn() && request.auth.uid != userId && (
        isSystemAdmin() ||
        (hasUserDoc() && 
          (getUserData().get('tipo', null) == 'admin' || 
           getUserData().get('tipo', null) == 'super_admin' || 
           getUserData().get('tipo', null) == 'admin_institucional' || 
           getUserData().get('tipo', null) == 'prefeitura' || 
           getUserData().get('tipo', null) == 'empresa') &&
          (resource != null && isSameTenant(resource.data)) && 
          isSameTenant(request.resource.data)
        )
      );

      allow delete: if isSignedIn() && request.auth.uid != userId && isSystemAdmin();
    }

    // --- Appointments Collection Rules ---
    match /appointments/{appointmentId} {
      allow read, write: if isSystemAdmin();
      allow get, list: if isSignedIn() && resource != null && (
        (resource.data.get('patientId', null) == request.auth.uid ||
         resource.data.get('therapistId', null) == request.auth.uid) &&
        isSameTenant(resource.data)
      );
      allow create: if isSignedIn() && (
        (incoming().get('patientId', null) == request.auth.uid ||
         incoming().get('therapistId', null) == request.auth.uid) &&
        isSameTenant(incoming())
      );
      allow update: if isSignedIn() && resource != null && (
        (resource.data.get('patientId', null) == request.auth.uid ||
         resource.data.get('therapistId', null) == request.auth.uid) &&
        isSameTenant(resource.data) &&
        isSameTenant(incoming())
      );
    }

    // --- Messages Collection Rules ---
    match /messages/{messageId} {
      allow read, write: if isSystemAdmin();
      allow get, list: if isSignedIn() && resource != null && (
        resource.data.get('senderId', null) == request.auth.uid ||
        resource.data.get('receiverId', null) == request.auth.uid
      );
      allow create: if isSignedIn() && (
        incoming().get('senderId', null) == request.auth.uid
      );
    }

    // --- Emotion Logs Collection Rules ---
    match /emotion_logs/{logId} {
      allow read, write: if isSystemAdmin();
      allow get, list: if isSignedIn() && (resource == null || resource.data.get('userId', null) == request.auth.uid);
      allow create: if isSignedIn() && incoming().get('userId', null) == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.get('userId', null) == request.auth.uid;
    }

    // --- Breathing Logs Collection Rules ---
    match /breathing_logs/{logId} {
      allow read, write: if isSystemAdmin();
      allow get, list: if isSignedIn() && (resource == null || resource.data.get('userId', null) == request.auth.uid);
      allow create: if isSignedIn() && incoming().get('userId', null) == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.get('userId', null) == request.auth.uid;
    }

    // --- IARA AI Memory Collection Rules ---
    match /memoria_iara/{userId} {
      allow read, write: if isSystemAdmin();
      allow read, write: if isOwner(userId);
    }

    // --- IARA Conversations Collection Rules ---
    match /iara_conversations/{conversationId} {
      allow read, write: if isSystemAdmin();
      allow get, list: if isSignedIn() && (resource == null || resource.data.get('userId', null) == request.auth.uid);
      allow create: if isSignedIn() && incoming().get('userId', null) == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.get('userId', null) == request.auth.uid;
    }

    // --- Diary Entries Collection Rules ---
    match /diary_entries/{entryId} {
      allow read, write: if isSystemAdmin();
      allow get, list: if isSignedIn() && (resource == null || resource.data.get('userId', null) == request.auth.uid);
      allow create: if isSignedIn() && incoming().get('userId', null) == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.get('userId', null) == request.auth.uid;
    }

    // --- Feedbacks Collection Rules ---
    match /feedbacks/{feedbackId} {
      allow read, write: if isSystemAdmin();
      allow get, list: if isSignedIn() && (resource == null || resource.data.get('userId', null) == request.auth.uid);
      allow create: if isSignedIn() && incoming().get('userId', null) == request.auth.uid;
    }

    // --- Private Clinical Notes Collection Rules ---
    match /private_notes/{noteId} {
      allow read, write: if isSystemAdmin();
      allow get, list: if isSignedIn() && resource != null && (
        (resource.data.get('patientId', null) == request.auth.uid ||
         resource.data.get('therapistId', null) == request.auth.uid) &&
        isSameTenant(resource.data)
      );
      allow create: if isSignedIn() && (
        incoming().get('therapistId', null) == request.auth.uid &&
        isSameTenant(incoming())
      );
      allow update, delete: if isSignedIn() && resource != null && (
        resource.data.get('therapistId', null) == request.auth.uid &&
        isSameTenant(resource.data) &&
        isSameTenant(incoming())
      );
    }

    // --- Security Audit Logs Collection Rules ---
    match /audit_logs/{logId} {
      allow read, write: if isSystemAdmin();
      // Audits must always be appendable to prevent race conditions during auth transitions
      allow create: if true;
      allow get, list: if isSignedIn() && resource != null && resource.data.get('userId', null) == request.auth.uid;
    }

    // --- Organizations Collection Rules ---
    match /organizations/{orgId} {
      allow read: if isSignedIn() && (
        isSystemAdmin() ||
        (hasUserDoc() && getUserData().get('tenantId', null) == orgId)
      );
      allow create, delete: if isSystemAdmin();
      allow update: if isSignedIn() && (
        isSystemAdmin() ||
        (
          hasUserDoc() && 
          getUserData().get('tenantId', null) == orgId && 
          (getUserData().get('tipo', null) == 'admin_institucional' || 
           getUserData().get('tipo', null) == 'empresa' || 
           getUserData().get('tipo', null) == 'prefeitura' || 
           getUserData().get('tipo', null) == 'clinica' || 
           getUserData().get('tipo', null) == 'hospital')
        )
      );
    }
  }
}
