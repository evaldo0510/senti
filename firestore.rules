rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net - deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Reusable, hardened global helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }

    function isSystemAdmin() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tipo == 'admin' || 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tipo == 'super_admin');
    }

    function hasUserDoc() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function getTenantId(data) {
      return ('tenantId' in data) ? data.tenantId : null;
    }

    function isSameTenant(data) {
      return !hasUserDoc() || getTenantId(data) == getTenantId(getUserData());
    }

    // --- Users Collection Rules ---
    match /users/{userId} {
      // Allow user to read/write their own document, but ensure tenantId matching if they already have a profile
      allow read: if isSignedIn() && (
        request.auth.uid == userId ||
        isSystemAdmin() ||
        (hasUserDoc() && isSameTenant(resource.data))
      );
      
      allow write: if isSignedIn() && (
        (request.auth.uid == userId && isSameTenant(request.resource.data)) ||
        isSystemAdmin() ||
        (hasUserDoc() && 
          (getUserData().tipo == 'admin' || 
           getUserData().tipo == 'super_admin' || 
           getUserData().tipo == 'admin_institucional' || 
           getUserData().tipo == 'prefeitura' || 
           getUserData().tipo == 'empresa') &&
          isSameTenant(resource.data) && 
          isSameTenant(request.resource.data)
        )
      );
    }

    // --- Appointments Collection Rules ---
    match /appointments/{appointmentId} {
      allow read, write: if isSystemAdmin();
      allow get, list: if isSignedIn() && resource != null && (
        (resource.data.patientId == request.auth.uid ||
         resource.data.therapistId == request.auth.uid) &&
        isSameTenant(resource.data)
      );
      allow create: if isSignedIn() && (
        (incoming().patientId == request.auth.uid ||
         incoming().therapistId == request.auth.uid) &&
        isSameTenant(incoming())
      );
      allow update: if isSignedIn() && resource != null && (
        (resource.data.patientId == request.auth.uid ||
         resource.data.therapistId == request.auth.uid) &&
        isSameTenant(resource.data) &&
        isSameTenant(incoming())
      );
    }

    // --- Messages Collection Rules ---
    match /messages/{messageId} {
      allow read, write: if isSystemAdmin();
      allow get, list: if isSignedIn() && resource != null && (
        resource.data.senderId == request.auth.uid ||
        resource.data.receiverId == request.auth.uid
      );
      allow create: if isSignedIn() && (
        incoming().senderId == request.auth.uid
      );
    }

    // --- Emotion Logs Collection Rules ---
    match /emotion_logs/{logId} {
      allow read, write: if isSystemAdmin();
      allow get, list: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // --- Breathing Logs Collection Rules ---
    match /breathing_logs/{logId} {
      allow read, write: if isSystemAdmin();
      allow get, list: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // --- IARA AI Memory Collection Rules ---
    match /memoria_iara/{userId} {
      allow read, write: if isSystemAdmin();
      allow read, write: if isOwner(userId);
    }

    // --- Diary Entries Collection Rules ---
    match /diary_entries/{entryId} {
      allow read, write: if isSystemAdmin();
      allow get, list: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // --- Feedbacks Collection Rules ---
    match /feedbacks/{feedbackId} {
      allow read, write: if isSystemAdmin();
      allow get, list: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
    }

    // --- Private Clinical Notes Collection Rules ---
    match /private_notes/{noteId} {
      allow read, write: if isSystemAdmin();
      allow get, list: if isSignedIn() && resource != null && (
        (resource.data.patientId == request.auth.uid ||
         resource.data.therapistId == request.auth.uid) &&
        isSameTenant(resource.data)
      );
      allow create: if isSignedIn() && (
        incoming().therapistId == request.auth.uid &&
        isSameTenant(incoming())
      );
      allow update, delete: if isSignedIn() && resource != null && (
        resource.data.therapistId == request.auth.uid &&
        isSameTenant(resource.data) &&
        isSameTenant(incoming())
      );
    }

    // --- Security Audit Logs Collection Rules ---
    match /audit_logs/{logId} {
      allow read, write: if isSystemAdmin();
      // Audits must always be appendable to prevent race conditions during auth transitions
      allow create: if true;
      allow get, list: if isSignedIn() && resource != null && resource.data.userId == request.auth.uid;
    }

    // --- Organizations Collection Rules ---
    match /organizations/{orgId} {
      allow read: if isSignedIn() && (
        isSystemAdmin() ||
        (hasUserDoc() && getUserData().tenantId == orgId)
      );
      allow create, delete: if isSystemAdmin();
      allow update: if isSignedIn() && (
        isSystemAdmin() ||
        (
          hasUserDoc() && 
          getUserData().tenantId == orgId && 
          (getUserData().tipo == 'admin_institucional' || 
           getUserData().tipo == 'empresa' || 
           getUserData().tipo == 'prefeitura' || 
           getUserData().tipo == 'clinica' || 
           getUserData().tipo == 'hospital')
        )
      );
    }
  }
}
