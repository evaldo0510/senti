rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if the user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }

    // Secure catch-all: Allow read/write ONLY for authenticated users
    match /{document=**} {
      allow read, write: if isSignedIn();
    }

    // Collection: Users (Fully protected by authentication)
    match /users/{userId} {
      allow read, write: if isSignedIn();
    }

    // Collection: Appointments (Fully protected by authentication)
    match /appointments/{appointmentId} {
      allow read, write: if isSignedIn();
    }

    // Collection: Messages (Fully protected by authentication)
    match /messages/{messageId} {
      allow read, write: if isSignedIn();
    }

    // Collection: Emotion Logs (Fully protected by authentication)
    match /emotion_logs/{logId} {
      allow read, write: if isSignedIn();
    }

    // Collection: Memoria Iara (Fully protected by authentication)
    match /memoria_iara/{userId} {
      allow read, write: if isSignedIn();
    }

    // Collection: Diary Entries (Fully protected by authentication)
    match /diary_entries/{entryId} {
      allow read, write: if isSignedIn();
    }

    // Collection: Feedbacks (Fully protected by authentication)
    match /feedbacks/{feedbackId} {
      allow read, write: if isSignedIn();
    }

    // Collection: Audit Logs (Fully protected by authentication)
    match /audit_logs/{logId} {
      allow read, write: if isSignedIn();
    }

    // Collection: Private Notes (Fully protected by authentication)
    match /private_notes/{noteId} {
      allow read, write: if isSignedIn();
    }
  }
}
