{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile for patients and therapists",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "displayName": { "type": "string", "description": "User's full name" },
        "email": { "type": "string", "format": "email", "description": "User's email" },
        "photoURL": { "type": "string", "description": "Profile picture URL" },
        "tipo": { "type": "string", "enum": ["usuario", "terapeuta", "empresa", "prefeitura", "clinica", "hospital", "admin"], "description": "User's type/role" },
        "especialidade": { "type": "string", "description": "Therapist's specialty" },
        "cidade": { "type": "string", "description": "Therapist's city" },
        "preco": { "type": "string", "description": "Therapist's price per session" },
        "rating": { "type": "number", "description": "Therapist's rating" },
        "reviews": { "type": "number", "description": "Number of reviews" },
        "online": { "type": "boolean", "description": "If therapist offers online sessions" },
        "presencial": { "type": "boolean", "description": "If therapist offers in-person sessions" },
        "biografia": { "type": "string", "description": "Therapist's bio" },
        "videoUrl": { "type": "string", "description": "Therapist's intro video URL" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" },
        "subscriptionStatus": { "type": "string", "enum": ["trial", "active", "expired", "cancelled"], "description": "Status of subscription" },
        "subscriptionPlan": { "type": "string", "enum": ["trial", "premium", "professional", "enterprise"], "description": "Plan name of subscription" },
        "trialStartDate": { "type": "string", "format": "date-time", "description": "Trial start date" },
        "trialEndDate": { "type": "string", "format": "date-time", "description": "Trial end date" },
        "paymentProvider": { "type": "string", "enum": ["stripe", "mercadopago"], "description": "Selected payment gateway" },
        "subscriptionId": { "type": "string", "description": "Gateway subscription ID" },
        "lastPayment": { "type": "string", "format": "date-time", "description": "Last payment timestamp" },
        "nextBilling": { "type": "string", "format": "date-time", "description": "Next billing/payment date" },
        "tenantId": { "type": "string", "description": "ID of the linked organization (multitenant)" }
      },
      "required": ["uid", "email", "tipo"]
    },
    "Journey": {
      "title": "Journey",
      "description": "Active therapeutic journey and context for care coordination",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Journey ID" },
        "userId": { "type": "string", "description": "Patient's Auth UID" },
        "objective": { "type": "string", "description": "Active care coordination objective" },
        "programs": { "type": "array", "description": "Active enrolled programs" },
        "professionals": { "type": "array", "description": "Linked care specialists (UIDs)" },
        "status": { "type": "string", "enum": ["active", "paused", "completed"], "description": "Journey status" },
        "streak": { "type": "number", "description": "Active check-in streak count" },
        "xp": { "type": "number", "description": "Total earned engagement XP" },
        "dailyGoal": { "type": "string", "description": "Active custom daily goal" },
        "currentPhase": { "type": "string", "enum": ["inicio", "desenvolvimento", "consolidacao"], "description": "Visual phase under Meu Jardim metaphor" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Last progress update timestamp" }
      },
      "required": ["userId", "objective", "status"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "Scheduled session between a patient and a therapist",
      "type": "object",
      "properties": {
        "patientId": { "type": "string", "description": "UID of the patient" },
        "therapistId": { "type": "string", "description": "UID of the therapist" },
        "date": { "type": "string", "format": "date-time", "description": "Session date and time" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled", "completed"], "description": "Appointment status" },
        "sharedSecret": { "type": "string", "description": "Shared secret for E2EE chat" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" },
        "tenantId": { "type": "string", "description": "ID of the linked organization (multitenant)" }
      },
      "required": ["patientId", "therapistId", "date", "status"]
    },
    "Professional": {
      "title": "Professional",
      "description": "Clinical therapist metadata and details",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Auth UID of the professional" },
        "crp": { "type": "string", "description": "Professional registration number" },
        "specialties": { "type": "array", "description": "Specialties offered" },
        "languages": { "type": "array", "description": "Languages spoken" },
        "availability": { "type": "object", "description": "Weekly calendar slots availability" },
        "address": { "type": "string", "description": "Physical clinical office address" },
        "tenantId": { "type": "string", "description": "Linked organization ID" },
        "verified": { "type": "boolean", "description": "Whether CRP is officially validated" }
      },
      "required": ["userId", "crp", "specialties"]
    },
    "Program": {
      "title": "Program",
      "description": "Therapeutic care program designed for specific mental conditions",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Program ID" },
        "title": { "type": "string", "description": "Program name" },
        "category": { "type": "string", "enum": ["ansiedade", "sono", "luto", "casal", "adolescente", "geral"], "description": "Program category matching care journeys" },
        "description": { "type": "string", "description": "Overview description" },
        "steps": { "type": "array", "description": "Sequential milestones or tasks" },
        "estimatedDays": { "type": "number", "description": "Average duration to complete" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation date" }
      },
      "required": ["id", "title", "category", "steps"]
    },
    "LibraryItem": {
      "title": "LibraryItem",
      "description": "Educational reading, meditation guides or PCH tracks",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Item ID" },
        "title": { "type": "string", "description": "Title" },
        "type": { "type": "string", "enum": ["meditacao", "leitura", "audio", "pch", "video"], "description": "Content type" },
        "content": { "type": "string", "description": "Full text or markdown description" },
        "mediaUrl": { "type": "string", "description": "URL of the audio/video file if applicable" },
        "category": { "type": "string", "description": "Target condition or topic" },
        "durationSeconds": { "type": "number", "description": "Content play duration" }
      },
      "required": ["id", "title", "type"]
    },
    "MarketplaceProduct": {
      "title": "MarketplaceProduct",
      "description": "Products, wellness courses or events on the SentiPae market",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Product ID" },
        "title": { "type": "string", "description": "Product or course title" },
        "description": { "type": "string", "description": "Meticulous description" },
        "price": { "type": "number", "description": "Item cost" },
        "category": { "type": "string", "enum": ["curso", "evento", "livro", "equipamento"], "description": "Product type" },
        "sellerId": { "type": "string", "description": "Therapist or org UID selling the item" },
        "imageUrl": { "type": "string", "description": "URL of product cover" },
        "rating": { "type": "number", "description": "Product reviews rating" }
      },
      "required": ["id", "title", "price", "category"]
    },
    "Subscription": {
      "title": "Subscription",
      "description": "SentiPae financial subscription tracking layer",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Subscription ID" },
        "userId": { "type": "string", "description": "User UID" },
        "plan": { "type": "string", "enum": ["trial", "premium", "professional", "enterprise"], "description": "Tier" },
        "status": { "type": "string", "enum": ["active", "cancelled", "expired", "paused"], "description": "Gateway status" },
        "amount": { "type": "number", "description": "Recurring price paid" },
        "period": { "type": "string", "enum": ["monthly", "annual"], "description": "Billing cadence" },
        "currentPeriodEnd": { "type": "string", "format": "date-time", "description": "Next billing date" },
        "gatewayId": { "type": "string", "description": "Stripe/MercadoPago reference" }
      },
      "required": ["userId", "plan", "status", "currentPeriodEnd"]
    },
    "Notification": {
      "title": "Notification",
      "description": "Push notification or in-app alarm tracking layer",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Notification ID" },
        "userId": { "type": "string", "description": "Target User UID" },
        "title": { "type": "string", "description": "Message Title" },
        "body": { "type": "string", "description": "Body message text" },
        "type": { "type": "string", "enum": ["alert", "info", "appointment", "chat"], "description": "Type classification" },
        "read": { "type": "boolean", "description": "Whether it was opened/read" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp" }
      },
      "required": ["userId", "title", "body", "read", "createdAt"]
    },
    "Consent": {
      "title": "Consent",
      "description": "Patient compliance consent and info-sharing authorization under LGPD rules",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Consent record ID" },
        "userId": { "type": "string", "description": "Auth UID of the patient" },
        "therapistId": { "type": "string", "description": "Auth UID of authorized professional" },
        "organizationId": { "type": "string", "description": "Auth ID of authorized company/prefeitura/clinic" },
        "granted": { "type": "boolean", "description": "Consent status" },
        "allowedData": { "type": "array", "description": "List of data permissions (mood, journals, care plan)" },
        "grantedAt": { "type": "string", "format": "date-time", "description": "Consent creation timestamp" },
        "revokedAt": { "type": "string", "format": "date-time", "description": "Consent revocation timestamp" }
      },
      "required": ["userId", "granted", "allowedData", "grantedAt"]
    },
    "Message": {
      "title": "Message",
      "description": "Chat message between users",
      "type": "object",
      "properties": {
        "senderId": { "type": "string", "description": "UID of the sender" },
        "receiverId": { "type": "string", "description": "UID of the receiver" },
        "text": { "type": "string", "description": "Message content" },
        "timestamp": { "type": "object", "description": "Firestore server timestamp" },
        "appointmentId": { "type": "string", "description": "Optional appointment context" },
        "read": { "type": "boolean", "description": "If message has been read" },
        "encrypted": { "type": "boolean", "description": "If message text is encrypted" },
        "audioUrl": { "type": "string", "description": "URL of the audio message" },
        "duration": { "type": "number", "description": "Duration of the audio message in seconds" }
      },
      "required": ["senderId", "receiverId", "text", "timestamp"]
    },
    "DiaryEntry": {
      "title": "DiaryEntry",
      "description": "Private diary entry for the user",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "UID of the user" },
        "title": { "type": "string", "description": "Entry title" },
        "content": { "type": "string", "description": "Entry content" },
        "timestamp": { "type": "string", "format": "date-time", "description": "Entry timestamp" }
      },
      "required": ["userId", "content", "timestamp"]
    },
    "EmotionLog": {
      "title": "EmotionLog",
      "description": "Log of user's emotional state",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "UID of the user" },
        "emotion": { "type": "string", "description": "Emotion name" },
        "intensity": { "type": "number", "description": "Intensity from 1 to 10" },
        "timestamp": { "type": "string", "format": "date-time", "description": "Log timestamp" }
      },
      "required": ["userId", "emotion", "intensity", "timestamp"]
    },
    "MemoriaIara": {
      "title": "MemoriaIara",
      "description": "IARA's memory of the user's emotional profile and history",
      "type": "object",
      "properties": {
        "perfil": {
          "type": "object",
          "properties": {
            "nome": { "type": "string" },
            "emocaoAtual": { "type": "string" },
            "padrao": { "type": "string" },
            "intensidade": { "type": "string" },
            "preferencia": { "type": "string" }
          }
        },
        "historico": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "dia": { "type": "number" },
              "emocao": { "type": "string" },
              "data": { "type": "string", "format": "date-time" }
            }
          }
        }
      },
      "required": ["perfil", "historico"]
    },
    "Feedback": {
      "title": "Feedback",
      "description": "User feedback and app evaluation",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "UID of the user" },
        "rating": { "type": "number", "description": "Rating from 1 to 5" },
        "comment": { "type": "string", "description": "User's suggestions or comments" },
        "timestamp": { "type": "string", "format": "date-time", "description": "Submission timestamp" }
      },
      "required": ["userId", "rating", "timestamp"]
    },
    "PrivateNote": {
      "title": "PrivateNote",
      "description": "Encrypted clinical session notes stored privately by therapists for specific patients",
      "type": "object",
      "properties": {
        "therapistId": { "type": "string", "description": "UID of the therapist who wrote the note" },
        "patientId": { "type": "string", "description": "UID of the patient" },
        "encryptedContent": { "type": "string", "description": "AES-encrypted content of the session note" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Last update timestamp" },
        "tenantId": { "type": "string", "description": "ID of the linked organization (multitenant)" }
      },
      "required": ["therapistId", "patientId", "encryptedContent", "createdAt", "updatedAt"]
    },
    "Organization": {
      "title": "Organization",
      "description": "Company, municipality or clinic (multitenant tenant)",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier / tenant ID" },
        "name": { "type": "string", "description": "Organization's display name" },
        "tipo": { "type": "string", "enum": ["prefeitura", "clinica", "empresa", "hospital", "outra"], "description": "Organization category" },
        "active": { "type": "boolean", "description": "If organization is active" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" },
        "domain": { "type": "string", "description": "Optional email domain for auto-onboarding" },
        "maxUsers": { "type": "number", "description": "Maximum allowed linked users" },
        "logoUrl": { "type": "string", "description": "URL of organization's logo" },
        "contatoEmail": { "type": "string", "format": "email", "description": "Primary contact email" },
        "contatoTelefone": { "type": "string", "description": "Primary contact phone" },
        "indicadores": {
          "type": "object",
          "properties": {
            "totalConsultas": { "type": "number" },
            "humorMedio": { "type": "number" },
            "nivelEstresse": { "type": "number" },
            "totalMensagensIara": { "type": "number" }
          }
        }
      },
      "required": ["id", "name", "tipo", "active", "createdAt"]
    },
    "FinancialPlan": {
      "title": "FinancialPlan",
      "description": "Plan configuration details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "period": { "type": "string" },
        "features": { "type": "array" },
        "category": { "type": "string" }
      },
      "required": ["id", "name", "price", "period"]
    },
    "Payment": {
      "title": "Payment",
      "description": "Payment record for subscription or booking",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string" },
        "provider": { "type": "string" },
        "subId": { "type": "string" },
        "appointmentId": { "type": "string" },
        "type": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "userId", "amount", "status", "type", "createdAt"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Ledger entry for auditing",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string" },
        "amount": { "type": "number" },
        "description": { "type": "string" },
        "referenceId": { "type": "string" },
        "referenceType": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "userId", "type", "amount", "status", "createdAt"]
    },
    "Invoice": {
      "title": "Invoice",
      "description": "Invoice for customer billing records",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "subscriptionId": { "type": "string" },
        "paymentId": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string" },
        "invoiceNumber": { "type": "string" },
        "dueDate": { "type": "string" },
        "paidAt": { "type": "string" },
        "pdfUrl": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "userId", "paymentId", "amount", "status", "invoiceNumber", "dueDate", "createdAt"]
    },
    "Commission": {
      "title": "Commission",
      "description": "Platform cuts and professional split metrics",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "appointmentId": { "type": "string" },
        "productId": { "type": "string" },
        "therapistId": { "type": "string" },
        "totalAmount": { "type": "number" },
        "commissionPercentage": { "type": "number" },
        "commissionAmount": { "type": "number" },
        "therapistAmount": { "type": "number" },
        "status": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "therapistId", "totalAmount", "commissionPercentage", "commissionAmount", "therapistAmount", "status", "createdAt"]
    },
    "Payout": {
      "title": "Payout",
      "description": "Earnings distributions sent to professionals",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "therapistId": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string" },
        "bankName": { "type": "string" },
        "bankAgency": { "type": "string" },
        "bankAccount": { "type": "string" },
        "pixKeyType": { "type": "string" },
        "pixKey": { "type": "string" },
        "paidAt": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "therapistId", "amount", "status", "createdAt"]
    },
    "Coupon": {
      "title": "Coupon",
      "description": "Promotional discounts",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "code": { "type": "string" },
        "discountPercentage": { "type": "number" },
        "active": { "type": "boolean" },
        "maxUses": { "type": "number" },
        "currentUses": { "type": "number" },
        "validUntil": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "code", "discountPercentage", "active", "maxUses", "currentUses", "validUntil", "createdAt"]
    },
    "BillingEvent": {
      "title": "BillingEvent",
      "description": "Billing events logged for audit trail",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "eventType": { "type": "string" },
        "payload": { "type": "object" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "userId", "eventType", "createdAt"]
    }
  },
  "firestore": {
    "users": {
      "schema": "User",
      "description": "Collection of user profiles"
    },
    "journeys": {
      "schema": "Journey",
      "description": "Collection of active client care journeys and continuous profiles"
    },
    "appointments": {
      "schema": "Appointment",
      "description": "Collection of scheduled sessions"
    },
    "professionals": {
      "schema": "Professional",
      "description": "Collection of professional therapist details, CRP credentials and calendar config"
    },
    "messages": {
      "schema": "Message",
      "description": "Collection of chat messages"
    },
    "emotion_logs": {
      "schema": "EmotionLog",
      "description": "Collection of emotional state logs"
    },
    "memoria_iara": {
      "schema": "MemoriaIara",
      "description": "Collection of IARA's memory for each user"
    },
    "diary_entries": {
      "schema": "DiaryEntry",
      "description": "Collection of user diary entries"
    },
    "feedbacks": {
      "schema": "Feedback",
      "description": "Collection of user feedbacks"
    },
    "private_notes": {
      "schema": "PrivateNote",
      "description": "Collection of encrypted private therapist notes on patients"
    },
    "organizations": {
      "schema": "Organization",
      "description": "Collection of multitenant tenants"
    },
    "programs": {
      "schema": "Program",
      "description": "Collection of available care pathways and therapeutic modules"
    },
    "library": {
      "schema": "LibraryItem",
      "description": "Collection of available readings, exercises, meditations and hipnotic poesies"
    },
    "marketplace": {
      "schema": "MarketplaceProduct",
      "description": "Collection of products, courses and wellness items on marketplace"
    },
    "subscriptions": {
      "schema": "Subscription",
      "description": "Collection of financial plans and billing subscriptions"
    },
    "notifications": {
      "schema": "Notification",
      "description": "Collection of user push and in-app alert history notifications"
    },
    "consents": {
      "schema": "Consent",
      "description": "Collection of explicit patient consent locks for therapist and tenant data sharing under LGPD"
    },
    "plans": {
      "schema": "FinancialPlan",
      "description": "Collection of available subscription and licensing plans"
    },
    "payments": {
      "schema": "Payment",
      "description": "Collection of subscription, appointment, and product payment logs"
    },
    "transactions": {
      "schema": "Transaction",
      "description": "Collection of ledger transaction records for accounting and audit trail"
    },
    "invoices": {
      "schema": "Invoice",
      "description": "Collection of billing invoices for subscriptions and individual charges"
    },
    "commissions": {
      "schema": "Commission",
      "description": "Collection of financial split commission records for professional sales"
    },
    "payouts": {
      "schema": "Payout",
      "description": "Collection of payout history records for professional therapists"
    },
    "coupons": {
      "schema": "Coupon",
      "description": "Collection of promotional and discount coupons"
    },
    "billingEvents": {
      "schema": "BillingEvent",
      "description": "Collection of logged events related to financial and billing updates"
    }
  }
}
